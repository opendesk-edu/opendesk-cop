%%{init: {"flowchart": {"htmlLabels": false}} }%%
flowchart TB

    %% ==========================================
    %% CLASSES (Color Coding)
    %% ==========================================
    classDef iam fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef app fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    classDef external fill:#f5f5f5,stroke:#9e9e9e,stroke-width:1px,stroke-dasharray:5,5
    classDef infra fill:#fff3e0,stroke:#e65100,stroke-width:1px
    classDef deploy fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px

    %% ==========================================
    %% LEGEND
    %% ==========================================
    subgraph LEGEND[" "]
        direction LR
        L1[IAM & Portal]:::iam
        L2[Applications]:::app
        L3[Infrastructure]:::infra
        L4[External]:::external
    end
    style LEGEND fill:#0000,stroke:#0000

    %% ==========================================
    %% LAYER 1: EXTERNAL SYSTEMS
    %% ==========================================
    subgraph EXT["External"]
        EXT_MTA[External MTAs<br/>Mail Relay / MX]:::external
        EXT_CLIENT[Mail Clients<br/>Thunderbird etc.]:::external
        EXT_SIP[SIP Trunk<br/>Phone]:::external
    end

    %% ==========================================
    %% LAYER 2: APPLICATIONS
    %% ==========================================
    subgraph APPS["Applications"]
        direction TB

        subgraph OX_SECTION["OX Ecosystem"]
            OX[OX App Suite<br/>Groupware]:::app
            DOVECOT[OX Dovecot<br/>Mail Backend]:::app
            PF[Postfix-Base<br/>Outbound MTA]:::app
            PFOX[Postfix-OX<br/>Mail Gateway]:::app
            OXC[OX Connector]:::app
        end

        subgraph NC_SECTION["Nextcloud Ecosystem"]
            NC[Nextcloud<br/>Files]:::app
            COLLAB[Collabora<br/>Weboffice]:::app
            CRYP[CryptPad<br/>Diagrams]:::app
        end

        OP[OpenProject<br/>Project Mgmt]:::app
        XW[XWiki<br/>Knowledge Mgmt]:::app
        EL[Element / Synapse<br/>Chat & Call]:::app
        JIT[Jitsi<br/>Video Conferencing]:::app
        NOTES[Notes / Docs]:::app
        INTERCOM[Intercom Service]:::app
        OPENPROJBOOT[openproject-bootstrap]:::app
    end

    %% ==========================================
    %% LAYER 3: IAM & PORTAL
    %% ==========================================
    subgraph IAM["IAM & Portal"]
        KC[Keycloak<br/>OIDC Provider]:::iam
        LDAP[OpenLDAP<br/>User Directory]:::iam
        PORTAL[Portal<br/>Navigation]:::iam
        PROV[Provisioning Service]:::iam
        UMC[UMC Admin Console]:::iam
        KCEXT[Keycloak Extensions<br/>Brute Force / MFA]:::iam
    end

    %% ==========================================
    %% LAYER 4: INFRASTRUCTURE
    %% ==========================================
    subgraph INFRA["Infrastructure Services"]
        CLAM[ClamAV<br/>Antivirus]:::infra
        AMQ[NATS<br/>Provisioning Queue]:::infra
    end

    %% ==========================================
    %% ============ EDGES ============
    %% ==========================================

    %% --- IAM Internal ---
    KC --> LDAP
    PORTAL --> KC
    UMC --> LDAP
    KCEXT --> KC
    PROV --> LDAP

    %% --- OIDC Auth (all apps authenticate via Keycloak) ---
    NC -->|OIDC| KC
    OX -->|OIDC| KC
    OP -->|OIDC| KC
    XW -->|OIDC| KC
    EL -->|OIDC| KC
    JIT -->|OIDC| KC
    INTERCOM -->|OIDC| KC
    DOVECOT -->|OIDC| KC

    %% --- Direct LDAP ---
    NC -->|LDAP| LDAP
    OP -->|LDAP| LDAP
    XW -->|LDAP| LDAP
    OX -->|LDAP| LDAP
    DOVECOT -->|LDAP| LDAP
    PORTAL -->|LDAP| LDAP
    PF -->|static SASL| LDAP

    %% --- Provisioning ---
    PROV --> OXC
    OXC -->|SOAP API| OX
    PROV --> AMQ

    %% --- Intercom (Frontend Integration Hub) ---
    OX -->|Silent Login| INTERCOM
    EL -->|Silent Login| INTERCOM
    INTERCOM -->|Token Exchange| KC
    INTERCOM -->|Filepicker| NC
    INTERCOM -->|Navigation| PORTAL
    INTERCOM -->|Newsfeed| XW
    PORTAL -->|Newsfeed| INTERCOM

    %% --- App-to-App Integration ---
    OX -->|Video Conf.| EL
    NC -->|Central Contacts| OX
    NC -->|Filepicker| OX
    OP -->|File Store| NC
    COLLAB -->|WOPI| NC
    CRYP -->|WebDAV| NC
    OPENPROJBOOT --> NC
    OPENPROJBOOT --> OP

    %% --- Mail Flow ---
    PF -->|outbound| EXT_MTA
    PFOX -->|inbound| EXT_MTA
    PFOX -->|auth| DOVECOT
    OX -->|OAuth| PFOX
    OX --> DOVECOT
    DOVECOT -->|Sieve| PF
    NC -->|system mail| PF
    OP -->|system mail| PF
    XW -->|system mail| PF
    EL -->|system mail| PF
    NOTES -->|system mail| PF
    EXT_CLIENT -->|LDAP| PFOX
    EXT_CLIENT --> DOVECOT
    CLAM --> PF

    %% --- Telephony ---
    EXT_SIP --> JIT

    %% ==========================================
    %% DEPLOYMENT ORDER (simplified linear chain)
    %% ==========================================
    subgraph DEPLOY["Deployment Order (helmfile)"]
        direction LR
        D1[1. Infra Services<br/>PG / MariaDB / MinIO /<br/>Redis / Memcached / ClamAV]:::deploy
        D2[2. Nubus<br/>Keycloak / OpenLDAP /<br/>Portal / Provisioning]:::deploy
        D3[3. OX + Mail<br/>AppSuite / Dovecot / Postfix]:::deploy
        D4[4. Nextcloud]:::deploy
        D5[5. Collabora + CryptPad]:::deploy
        D6[6. Jitsi + Element]:::deploy
        D7[7. OpenProject + XWiki]:::deploy
        D8[8. Notes]:::deploy
        D9[9. Bootstrap +<br/>Post-Migrations]:::deploy
        D1 --> D2 --> D3 --> D4 --> D5 --> D6 --> D7 --> D8 --> D9
    end
